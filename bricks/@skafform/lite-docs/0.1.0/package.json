{
  "name": "@skafform/lite-docs",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "skafform": {
    "requires": [],
    "scaffold": ["docs"],
    "nav": [
      { "label": "Docs", "href": "/docs", "location": "primary", "visibility": "public", "order": 50 }
    ],
    "routes": [
      { "path": "docs/search", "file": "src/routes/docs.search.tsx", "layout": false },
      { "path": "docs/*", "file": "src/routes/docs.$.tsx" }
    ]
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "react": "^19.0.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0"
  }
}
