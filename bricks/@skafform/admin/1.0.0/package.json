{
  "name": "@skafform/admin",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts"
  },
  "skafform": {
    "requires": ["core"],
    "requiresAdapters": ["auth"],
    "nav": [
      { "key": "admin", "label": "Administration", "href": "/admin", "location": "user-menu", "visibility": "admin", "order": 20 }
    ],
    "layout": "src/layouts/AdminLayout.tsx",
    "routes": [
      { "path": "admin",            "file": "src/routes/admin.tsx" },
      { "path": "admin/users",      "file": "src/routes/admin.users.tsx" },
      { "path": "admin/navigation", "file": "src/routes/admin.navigation.tsx" },
      { "path": "admin/theme",          "file": "src/routes/admin.theme.tsx" },
      { "path": "admin/customize",      "file": "src/routes/admin.customize.tsx" },
      { "path": "admin/pages",          "file": "src/routes/admin.pages.tsx" },
      { "path": "admin/pages/new",      "file": "src/routes/admin.pages.new.tsx" },
      { "path": "admin/pages/:id/edit", "file": "src/routes/admin.pages.$id.edit.tsx" },
      { "path": "admin/configuration",  "file": "src/routes/admin.configuration.tsx" }
    ]
  }
}
